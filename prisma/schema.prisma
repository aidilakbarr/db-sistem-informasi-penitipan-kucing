generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- ENUMS ---

enum Role {
  ADMIN
  CARETAKER
  COURIER
  CUSTOMER
}

enum CatRas {
  persia
  siamase
  scottish_fold     @map("scottish fold")
  maine_coon        @map("maine coon")
  anggora
  bengal
  siberian
  sphynx
  russian_blue      @map("russian blue")
  british_shorthair @map("british shorthair")
}

enum VaccinationStatus {
  vaccinated
  not_vaccinated @map("not vaccinated")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_CARE
  COMPLETED
  CANCELLED
}

enum ServiceType {
  BASIC
  PREMIUM
  DELUXE
}

enum AdditionalServices {
  GROOMING
  DELIVERY
}

enum CageStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
}

enum PaymentMethod {
  COD
  TRANSFER
  PAYMENT_GATEWAY
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

// --- MODELS ---

model User {
  id               String   @id @default(uuid())
  name             String
  email            String   @unique
  password         String
  role             Role     @default(CUSTOMER)
  
  refreshTokenHash String? 
  tokenVersion     Int      @default(0) 

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  cats             Cat[]  
  booking          Booking[]  

  @@index([email])
}

model Cat {
  id                    String            @id @default(uuid())
  name                  String
  ras                   CatRas
  age                   Int
  weight                Float
  medicalHistory        String            @db.Text
  vaccinationStatus     VaccinationStatus
  vaccineExpirationDate DateTime?
  specialNote           String?           @db.VarChar(200)

  ownerId               String
  owner                 User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  booking               Booking[]

  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
}

model Booking {
  id                 String              @id @default(uuid())
  checkInDate        DateTime
  checkOutDate       DateTime
  serviceType        ServiceType         @default(BASIC)
  additionalServices AdditionalServices?
  specialNote        String?             @db.Text
  status             BookingStatus       @default(PENDING)
  totalPrice         Float               @default(0)

  catId              String
  cat                Cat                 @relation(fields: [catId], references: [id], onDelete: Cascade)
  userId             String
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  cageId             String?
  cage               Cage?               @relation(fields: [cageId], references: [id]) 

  payment            Payment?   
   
  dailyLogs DailyLog[]        

  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([userId])
  @@index([catId])
}

model Cage {
  id          String      @id @default(uuid())
  cageNumber  String      @unique
  type        ServiceType @default(BASIC) 
  status      CageStatus  @default(AVAILABLE)
  description String?     @db.Text
  
  currentBookingId String?   @unique
  booking          Booking[]
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Payment {
  id             String        @id @default(uuid())
  amount         Float         
  method         PaymentMethod @default(TRANSFER)
  status         PaymentStatus @default(PENDING)
  proofOfPayment String?       
  adminNote      String?       @db.Text 

  bookingId      String        @unique
  booking        Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model DailyLog {
  id        String   @id @default(uuid())
  date      DateTime @default(now())
  condition String
  activity  String
  note      String?  @db.Text

  bookingId String
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}